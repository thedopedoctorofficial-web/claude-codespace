{
  "name": "Claude Code Workspace",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && echo '✅ Claude Code geïnstalleerd!'",
  "customizations": {
    "codespaces": {
      "openFiles": []
    }
  },
  "forwardPorts": [],
